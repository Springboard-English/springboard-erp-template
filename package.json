{
    "name": "@springboard-english/springboard-erp-template",
    "private": false,
    "version": "0.3.0",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/Springboard-English/springboard-erp-template.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/exports.d.ts",
    "exports": {
        ".": {
            "types": "./dist/exports.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc -p tsconfig.build.json",
        "preview": "vite preview",
        "lint": "eslint . --ext .ts,.tsx",
        "deploy": "VITE_BASE_URL=https://api.springboard.vn npm run build && gcloud storage rsync ./dist gs://lms.springboard.vn --recursive --delete-unmatched-destination-objects --exclude=\".*index[.]html$\" --cache-control=\"public, max-age=3600\" && gcloud storage cp ./dist/index.html  gs://lms.springboard.vn/index.html --cache-control=\"no-store, max-age=0\""
    },
    "dependencies": {
        "@react-spring/web": "latest",
        "@tanstack/react-query": "^5.90.21",
        "class-variance-authority": "^0.7.1",
        "clsx": "latest",
        "dayjs": "latest",
        "jose": "^6.2.1",
        "lucide-react": "^1.7.0",
        "radix-ui": "^1.4.3",
        "react": "latest",
        "react-dom": "latest",
        "react-router-dom": "latest",
        "shadcn": "^4.1.2",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "latest"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@types/react": "latest",
        "@types/react-dom": "latest",
        "@vitejs/plugin-react": "latest",
        "tailwindcss": "^4.2.2",
        "vite": "latest"
    }
}
